# Data files (managed by DVC)
data/processed/*.parquet
data/processed/*.csv
!data/processed/.gitkeep

# Raw downloaded data (regenerated by scripts/data_pipeline)
data/raw/real/

# Local backups
data/processed/*_backup.parquet

# Models (large binary files)
data/models/checkpoints/*.h5
data/models/checkpoints/*.pt
data/models/checkpoints/*.joblib
data/models/*.png

# Generated outputs (plots, evaluation reports from ModelEvaluator)
outputs/

# CatBoost training artifacts (binary tfevents, tsv logs — any location in tree)
catboost_info/

# Experiment tracking
experiments/*.json

# pytest-benchmark results
.benchmarks/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# OS
.DS_Store
Thumbs.db
desktop.ini
.hypothesis/
