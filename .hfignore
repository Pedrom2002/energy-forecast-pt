# What Hugging Face Spaces should skip when mirroring the GitHub repo.
#
# The Space only needs: src/, frontend/dist (built by the Dockerfile),
# data/models/ (baked into the image), README.md (with the YAML
# frontmatter), Dockerfile, and requirements.txt. Everything else is
# either regenerated during build or is dead weight that slows startup
# and pushes the Space over the 10 MiB-per-file limit.

# Large raw data — regenerated by scripts/refresh_and_retrain.sh
data/raw/
data/processed/*.parquet
data/processed/*.csv

# DVC metadata — the Space doesn't need to re-run the pipeline
*.dvc
.dvc/
dvc.lock

# Test + coverage artefacts
.pytest_cache/
htmlcov/
.coverage
.mutmut-cache
mutmut_config.py

# Build outputs that the Dockerfile regenerates
frontend/node_modules/
frontend/dist/
frontend/playwright-report/
frontend/test-results/
node_modules/

# Python caches + virtualenvs
__pycache__/
*.pyc
.venv/
venv/
env/

# Training notebooks + outputs (not needed for serving)
notebooks/
outputs/
catboost_info/
experiments/

# Deployment configs for other clouds (not used by HF Spaces)
deploy/
nginx/

# Local dev
.env
.env.local
*.log
logs/

# IDE / editor
.vscode/
.idea/
.DS_Store
