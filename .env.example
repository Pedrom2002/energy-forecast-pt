# ─────────────────────────────────────────────────────────────────────────────
# Energy Forecast PT — environment variable reference
#
# Copy this file to .env and fill in the values appropriate for your
# environment.  The .env file is excluded from version control (.gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── API Security ──────────────────────────────────────────────────────────────
# Secret key for X-API-Key authentication.
# When not set, authentication is DISABLED (development mode only).
# In production always set a strong, random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secret-api-key-here

# Separate high-entropy key for privileged admin endpoints (/admin/reload-models).
# Falls back to API_KEY when not set.  In production use a distinct secret so
# regular API consumers cannot trigger administrative operations.
#   python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your-admin-api-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Defaults to localhost:3000, localhost:8000, localhost:8080 when not set.
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum number of requests per IP within the sliding window.
RATE_LIMIT_MAX=60

# Sliding window size in seconds.
RATE_LIMIT_WINDOW=60

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Redis connection URL for distributed rate limiting.
# Requires: pip install redis
# When not set, rate limiting uses an in-memory backend (single-process only).
# The API falls back to in-memory automatically if Redis is unreachable.
REDIS_URL=redis://localhost:6379

# ── Model Files ───────────────────────────────────────────────────────────────
# Path to the models directory containing checkpoints/, metadata/, features/.
# Override when the data volume is mounted at a non-default location in containers.
# Defaults to data/models/ relative to the project root when not set.
MODELS_DIR=data/models

# ── Logging ───────────────────────────────────────────────────────────────────
# Application log level.  One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Emit a WARNING log when a request takes longer than this many milliseconds.
# Useful for catching unexpectedly slow inference without requiring APM.
SLOW_REQUEST_THRESHOLD_MS=5000

# ── Proxy / Load Balancer ─────────────────────────────────────────────────────
# Set to "1" when the API runs behind a trusted reverse proxy (nginx, AWS ALB,
# GCP GCLB, Azure Front Door) so that X-Forwarded-For is used for client IP
# extraction and rate limiting.  Set to "0" for direct internet exposure.
TRUST_PROXY=1

# ── Request Body Limit ────────────────────────────────────────────────────────
# Maximum allowed Content-Length in bytes.  Requests larger than this are
# rejected with 413 before Pydantic validation runs (OOM protection).
# Default: 2 097 152 (2 MB) — comfortably above max batch of 1 000 × EnergyData.
MAX_REQUEST_BODY_BYTES=2097152

# ── Prediction Timeout ────────────────────────────────────────────────────────
# Maximum wall-clock time (seconds) for a single prediction call.
# Protects the event loop from hanging on slow/corrupted models.
# Batch and sequential endpoints add per-item headroom on top of this.
PREDICTION_TIMEOUT_SECONDS=30

# Per-item timeout headroom for batch predictions (milliseconds).
# Total batch timeout = PREDICTION_TIMEOUT_SECONDS + N × (this / 1000).
BATCH_TIMEOUT_PER_ITEM_MS=50

# Per-step timeout headroom for sequential (auto-regressive) predictions (ms).
# Total sequential timeout = PREDICTION_TIMEOUT_SECONDS + N × (this / 1000).
SEQUENTIAL_TIMEOUT_PER_STEP_MS=100

# ── CI Coverage Monitoring ────────────────────────────────────────────────────
# Sliding-window size (number of observations) for empirical CI coverage
# tracking via GET /model/coverage.  Default: 168 = 1 week of hourly data.
COVERAGE_WINDOW_SIZE=168

# Coverage fraction below which GET /model/coverage returns alert: true.
# At nominal 90% CI, alert fires when empirical coverage drops below this.
# Default: 0.80 (80%).  Tighten to 0.85 for stricter alerting.
COVERAGE_ALERT_THRESHOLD=0.80

# ── Deployment Monitoring ─────────────────────────────────────────────────────
# Email address to receive CloudWatch / Cloud Monitoring / App Insights alerts.
# Used by deploy/deploy-aws.sh, deploy/deploy-gcp.sh, deploy/deploy-azure.sh.
ALERT_EMAIL=your@email.com

# Skip post-deploy monitoring setup (set to 1 to disable alert creation).
SKIP_MONITORING=0

# ── GCP Cloud Run ─────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
SERVICE_NAME=energy-forecast-api

# ── AWS ECS Fargate ───────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
ECR_REPOSITORY=energy-forecast-api
ECS_CLUSTER=energy-forecast-cluster
ECS_SERVICE=energy-forecast-service
AWS_ACCOUNT_ID=123456789012

# ── Azure Container Apps ──────────────────────────────────────────────────────
RESOURCE_GROUP=energy-forecast-rg
LOCATION=eastus
CONTAINER_APP_NAME=energy-forecast-api
CONTAINER_APP_ENV=energy-forecast-env
APP_INSIGHTS_NAME=energy-forecast-ai
REGISTRY_SERVER=your-registry.azurecr.io
IMAGE_NAME=energy-forecast-api
IMAGE_TAG=latest
